# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=troque-por-uma-chave-aleatoria-de-256-bits
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
DJANGO_SETTINGS_MODULE=core.settings.local

# ---------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://jurisagenda_user:jurisagenda_pass@db:5432/jurisagenda

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------------------------------------------------------------------
# MinIO
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jurisagenda-docs
MINIO_USE_SSL=False

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------------
# CORS — liberado para dev local
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1

# ---------------------------------------------------------------------------
# E-mail
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@jurisagenda.com.br
EMAIL_HOST_PASSWORD=senha_do_email
DEFAULT_FROM_EMAIL=noreply@jurisagenda.com.br

# ---------------------------------------------------------------------------
# Observabilidade
# ---------------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO

# Google TTS
GOOGLE_TTS_API_KEY=sua_chave_aqui