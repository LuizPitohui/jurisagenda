# ── JurisAgenda – Variáveis de Ambiente ──────────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de rodar o projeto.

# ── Django ────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=jurisagenda-dev-secret-key-12345!@#$%
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=core.settings.development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
DB_NAME=jurisagenda
DB_USER=jurisagenda_user
DB_PASSWORD=jurisagenda_pass
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jurisagenda-docs
MINIO_USE_SSL=False
MINIO_PRESIGNED_UPLOAD_TTL=900
MINIO_PRESIGNED_DOWNLOAD_TTL=3600
MINIO_MAX_UPLOAD_SIZE_MB=50

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws
NEXT_PUBLIC_APP_NAME=JurisAgenda

# ── TV Panel ──────────────────────────────────────────────────────────────
TV_HIGH_PRIORITY_RETRY_SECONDS=30
TV_CALL_HISTORY_SIZE=3

# ── Follow-up ─────────────────────────────────────────────────────────────
FOLLOWUP_TRIGGER_DELAY_MINUTES=30
FOLLOWUP_CHECK_INTERVAL_MINUTES=15

# ── Sentry (opcional, produção) ───────────────────────────────────────────
SENTRY_DSN=

# ── Email (produção) ──────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@jurisagenda.com.br
